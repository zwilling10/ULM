<Window x:Class="ULM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Linux Manager"
        Width="1160" Height="750" MinWidth="900" MinHeight="580"
        Background="{StaticResource BrushBg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Vorlage für eine einzelne Distro-Zeile (mit Spalten) ────── -->
        <DataTemplate x:Key="EntryTemplate">
            <Border Padding="0,5"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                    Background="Transparent"
                    MouseLeftButtonDown="EntryRow_MouseLeftButtonDown">
                <!--
                    Kein Tooltip auf dem Border (= gesamte Zeile) mehr.
                    Der Tooltip erscheint jetzt ausschließlich wenn der
                    Mauszeiger über dem Distro-Namen (Spalte 1) steht.
                -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="418"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!--
                        Tooltip NUR auf dem Namens-TextBlock — nicht auf der
                        gesamten Zeile. ToolTipService.IsEnabled wird über
                        den ChkShowInfo-Schalter in der Statusleiste gesteuert.
                    -->
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               Foreground="{Binding ForegroundBrush}"
                               FontSize="12.5" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding TipTooltip}"
                               ToolTipService.ShowDuration="20000"
                               ToolTipService.InitialShowDelay="400">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ChkShowInfo}"
                                                 Value="False">
                                        <Setter Property="ToolTipService.IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Column="2" Text="{Binding LocalStatus}"
                               Foreground="{StaticResource BrushMid}"
                               FontSize="11.5" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="3" Text="{Binding UsbStatus}"
                               Foreground="{StaticResource BrushMid}"
                               FontSize="11.5" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="4" Text="{Binding VersionStatus}"
                               Foreground="{StaticResource BrushMid}"
                               FontSize="11.5" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── Vorlage für eine Kategorie-Gruppe mit Sammel-Checkbox ───── -->
        <DataTemplate x:Key="CategoryTemplate">
            <StackPanel Margin="0,0,0,2">
                <Border Background="{StaticResource BrushCard}" Padding="14,8" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding AllSelected, Mode=TwoWay}"
                                  IsThreeState="True"
                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                  ToolTip="Alle Distros dieser Kategorie an-/abwählen"/>
                        <TextBlock Text="{Binding CategoryLabel}"
                                   FontWeight="Bold" FontSize="13.5"
                                   Foreground="{StaticResource BrushHeader}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding Entries}"
                              ItemTemplate="{StaticResource EntryTemplate}"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource BrushHeader}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{StaticResource BrushBlue}" Margin="0,0,12,0">
                        <TextBlock Text="UL" Foreground="White" FontWeight="Bold"
                                   FontSize="14" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Universal Linux Manager"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   FontFamily="{StaticResource FontMain}"/>
                        <TextBlock Text="USB-Stick einrichten · Linux ISOs verwalten · Downloads überwachen"
                                   Foreground="{StaticResource BrushDim}" FontSize="10"
                                   FontFamily="{StaticResource FontMain}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">

                    <Border Visibility="{Binding OnlineScanActive, Converter={StaticResource BoolToVis}}"
                            Background="#0D2035" CornerRadius="5"
                            Padding="10,6" Margin="0,0,10,0" MinWidth="140">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="🌐 Online-Scan"
                                           Foreground="{StaticResource BrushDim}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding OnlineScanPercent, Mode=OneWay, StringFormat={}{0}%}"
                                           Foreground="White" FontSize="9" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <ProgressBar Value="{Binding OnlineScanPercent, Mode=OneWay}" Maximum="100"
                                         Height="5" Margin="0,4,0,0"
                                         Background="#1A3355" Foreground="#0075BE" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Visibility="{Binding UsbScanActive, Converter={StaticResource BoolToVis}}"
                            Background="#0D2035" CornerRadius="5"
                            Padding="10,6" Margin="0,0,10,0" MinWidth="130">
                        <StackPanel>
                            <TextBlock Text="💾 Stick-Scan"
                                       Foreground="{StaticResource BrushDim}"
                                       FontSize="9" FontWeight="SemiBold"/>
                            <ProgressBar IsIndeterminate="True" Height="5" Margin="0,4,0,0"
                                         Background="#1A3355" Foreground="#27AE60" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Visibility="{Binding HealthCheckActive, Converter={StaticResource BoolToVis}}"
                            Background="#0D2035" CornerRadius="5"
                            Padding="10,6" Margin="0,0,16,0" MinWidth="140">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="🩺 Gesundheitscheck"
                                           Foreground="{StaticResource BrushDim}"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding HealthCheckPercent, Mode=OneWay, StringFormat={}{0}%}"
                                           Foreground="White" FontSize="9" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <ProgressBar Value="{Binding HealthCheckPercent, Mode=OneWay}" Maximum="100"
                                         Height="5" Margin="0,4,0,0"
                                         Background="#1A3355" Foreground="#0075BE" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Width="1" Height="28" Background="#2A4A6A" Margin="0,0,14,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OnlineScanActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UsbScanActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthCheckActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Button x:Name="BtnModeToggle" Style="{StaticResource BtnGhost}"
                            Foreground="White" BorderBrush="#4A6785"
                            Click="BtnModeToggle_Click" Width="160" Margin="0,0,8,0"/>

                    <Button x:Name="BtnHelp" Content="❓ Hilfe"
                            Style="{StaticResource BtnGhost}"
                            Foreground="White" BorderBrush="#4A6785"
                            Click="BtnHelp_Click" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Toolbar: Laufwerk / Ventoy ─────────────────────────────── -->
        <Border Grid.Row="1" Background="{StaticResource BrushWhite}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="ZIEL-USB-LAUFWERK"
                           FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrushDim}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <ComboBox Grid.Column="1" x:Name="DriveCombo"
                          ItemsSource="{Binding Drives}"
                          SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"/>

                <Button Grid.Column="2" x:Name="BtnRefreshDrives"
                        Content="↻" Style="{StaticResource BtnGhost}"
                        Width="32" Height="32" FontSize="16"
                        ToolTip="Laufwerke neu einlesen"
                        Click="BtnRefreshDrives_Click"/>

                <Button Grid.Column="3" x:Name="BtnVentoy"
                        Content="⚡ Ventoy installieren"
                        Style="{StaticResource BtnSuccess}"
                        Margin="10,0,0,0" Click="BtnVentoy_Click"/>

                <CheckBox Grid.Column="4" x:Name="ChkSecureBoot"
                          Content="🔒 Secure Boot" Margin="14,0,0,0"
                          VerticalAlignment="Center"
                          Checked="ChkSecureBoot_Changed"
                          Unchecked="ChkSecureBoot_Changed"/>

                <TextBlock Grid.Column="6" x:Name="DriveInfoTxt"
                           Text="{Binding DriveInfoText}"
                           Foreground="{StaticResource BrushBlue}"
                           FontWeight="SemiBold" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ── Haupt-Inhalt ────────────────────────────────────────────── -->
        <TabControl Grid.Row="2" x:Name="MainTabs" Margin="0">

            <TabItem Header="ISO-Auswahl">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushCard}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                            Padding="0,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="418"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Linux-Distribution  (Haken = Download)"
                                       FontWeight="Bold" FontSize="11" Foreground="{StaticResource BrushMid}"/>
                            <TextBlock Grid.Column="2" Text="Lokal"
                                       FontWeight="Bold" FontSize="11" Foreground="{StaticResource BrushMid}"/>
                            <TextBlock Grid.Column="3" Text="Auf dem Stick"
                                       FontWeight="Bold" FontSize="11" Foreground="{StaticResource BrushMid}"/>
                            <TextBlock Grid.Column="4" Text="Aktuell"
                                       FontWeight="Bold" FontSize="11" Foreground="{StaticResource BrushMid}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BrushWhite}">
                        <ItemsControl ItemsSource="{Binding Categories}"
                                      ItemTemplate="{StaticResource CategoryTemplate}"
                                      Margin="4,2,4,12"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Protokoll" x:Name="LogTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="LogBox"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="11" BorderThickness="0"
                             Background="{StaticResource BrushWhite}"/>
                    <Button Grid.Row="1" Content="Protokoll leeren"
                            Style="{StaticResource BtnGhost}"
                            HorizontalAlignment="Right" Margin="8"
                            Click="BtnClearLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Aktions-Leiste ──────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{StaticResource BrushWhite}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button x:Name="BtnDownload" Content="⬇  Herunterladen"
                            Style="{StaticResource BtnPrimary}" Width="180"
                            Click="BtnDownload_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnUpdates" Content="↻  Updates prüfen"
                            Style="{StaticResource BtnWarning}" Width="150"
                            Click="BtnUpdates_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnCancel" Content="✕  Stopp"
                            Style="{StaticResource BtnDanger}" Width="100"
                            Visibility="Collapsed" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SpeedLbl" VerticalAlignment="Center"
                               Foreground="{StaticResource BrushBlue}"
                               FontSize="11.5" Margin="8,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" x:Name="ExpertBar"
                            Orientation="Horizontal" Margin="0,0,0,6">
                    <Button x:Name="BtnCheckUrls" Content="🌐  URLs prüfen"
                            Style="{StaticResource BtnGhost}" Width="130"
                            Click="BtnCheckUrls_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSearch" Content="🔍  ISO suchen"
                            Style="{StaticResource BtnGhost}" Width="130"
                            Click="BtnSearch_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnEditDb" Content="🗃  Datenbank"
                            Style="{StaticResource BtnGhost}" Width="130"
                            Click="BtnEditDb_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnHealthCheck" Content="🩺  DB-Gesundheitscheck"
                            Style="{StaticResource BtnGhost}" Width="170"
                            ToolTip="Prüft für alle Distros in der Datenbank, ob sie aktuell online erreichbar und ladbar sind."
                            Click="BtnHealthCheck_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnCopyUsb" Content="📋  Auf Stick kopieren"
                            Style="{StaticResource BtnGhost}" Width="160"
                            Click="BtnCopyUsb_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnGitHubToken" Content="🔑  GitHub-Token"
                            Style="{StaticResource BtnGhost}" Width="130"
                            ToolTip="Optional: hebt das API-Limit für GitHub-basierte Distros von 60 auf 5000 Anfragen/Std an."
                            Click="BtnGitHubToken_Click"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" x:Name="ProgressBar"
                                 Height="5" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="FooterLbl"
                               Foreground="{StaticResource BrushDim}"
                               FontSize="10.5" VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Statusleiste ────────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusLbl"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource BrushMid}"/>
                <CheckBox Grid.Column="1" x:Name="ChkShowInfo"
                          Content="Info-Fenster (Mouseover) anzeigen"
                          IsChecked="True" FontSize="10.5"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
