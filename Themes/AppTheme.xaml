<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Farben ═════════════════════════════════════════════════════ -->
    <Color x:Key="ColBg"      >#F0F4F8</Color>
    <Color x:Key="ColWhite"   >#FFFFFF</Color>
    <Color x:Key="ColHeader"  >#0F2540</Color>
    <Color x:Key="ColBlue"    >#0075BE</Color>
    <Color x:Key="ColMid"     >#4A6785</Color>
    <Color x:Key="ColDim"     >#8BA3BE</Color>
    <Color x:Key="ColBorder"  >#C5D5E5</Color>
    <Color x:Key="ColCard"    >#E4EBF2</Color>
    <Color x:Key="ColGreen"   >#27AE60</Color>
    <Color x:Key="ColAmber"   >#E67E22</Color>
    <Color x:Key="ColRed"     >#C0392B</Color>
    <Color x:Key="ColTeal"    >#1ABC9C</Color>
    <Color x:Key="ColLBlue"   >#D6ECFA</Color>
    <Color x:Key="ColLGreen"  >#E8F8F0</Color>
    <Color x:Key="ColLRed"    >#FDE8E8</Color>
    <Color x:Key="ColLAmber"  >#FEF5E7</Color>

    <!-- ═══ Brushes ════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BrushBg"      Color="{StaticResource ColBg}"/>
    <SolidColorBrush x:Key="BrushWhite"   Color="{StaticResource ColWhite}"/>
    <SolidColorBrush x:Key="BrushHeader"  Color="{StaticResource ColHeader}"/>
    <SolidColorBrush x:Key="BrushBlue"    Color="{StaticResource ColBlue}"/>
    <SolidColorBrush x:Key="BrushMid"     Color="{StaticResource ColMid}"/>
    <SolidColorBrush x:Key="BrushDim"     Color="{StaticResource ColDim}"/>
    <SolidColorBrush x:Key="BrushBorder"  Color="{StaticResource ColBorder}"/>
    <SolidColorBrush x:Key="BrushCard"    Color="{StaticResource ColCard}"/>
    <SolidColorBrush x:Key="BrushGreen"   Color="{StaticResource ColGreen}"/>
    <SolidColorBrush x:Key="BrushAmber"   Color="{StaticResource ColAmber}"/>
    <SolidColorBrush x:Key="BrushRed"     Color="{StaticResource ColRed}"/>
    <SolidColorBrush x:Key="BrushTeal"    Color="{StaticResource ColTeal}"/>
    <SolidColorBrush x:Key="BrushLBlue"   Color="{StaticResource ColLBlue}"/>
    <SolidColorBrush x:Key="BrushLGreen"  Color="{StaticResource ColLGreen}"/>
    <SolidColorBrush x:Key="BrushLRed"    Color="{StaticResource ColLRed}"/>
    <SolidColorBrush x:Key="BrushLAmber"  Color="{StaticResource ColLAmber}"/>
    <SolidColorBrush x:Key="BrushTransparent" Color="Transparent"/>

    <!-- ═══ Schriften ══════════════════════════════════════════════════ -->
    <FontFamily x:Key="FontMain">Segoe UI, Tahoma, Arial</FontFamily>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeNormal">12</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeSmall">10.5</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeLarge">14</System:Double>

    <!-- ═══ Button-Basisstil ══════════════════════════════════════════ -->
    <Style x:Key="BtnBase" TargetType="Button">
        <Setter Property="FontFamily"      Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"        Value="11.5"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="14,7"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primär (Blau) -->
    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"  Value="{StaticResource BrushBlue}"/>
        <Setter Property="Foreground"  Value="White"/>
    </Style>

    <!-- Erfolg (Grün) -->
    <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"  Value="{StaticResource BrushGreen}"/>
        <Setter Property="Foreground"  Value="White"/>
    </Style>

    <!-- Warnung (Amber) -->
    <Style x:Key="BtnWarning" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"  Value="{StaticResource BrushAmber}"/>
        <Setter Property="Foreground"  Value="White"/>
    </Style>

    <!-- Gefahr (Rot) -->
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"  Value="{StaticResource BrushRed}"/>
        <Setter Property="Foreground"  Value="White"/>
    </Style>

    <!-- Ghost (Rahmen) -->
    <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushMid}"/>
    </Style>

    <!-- Sekundär (Card-Hintergrund) -->
    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
        <Setter Property="Background"  Value="{StaticResource BrushCard}"/>
        <Setter Property="Foreground"  Value="{StaticResource BrushMid}"/>
    </Style>

    <!-- ═══ TextBox ════════════════════════════════════════════════════ -->
    <Style TargetType="TextBox">
        <Setter Property="FontFamily"      Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background"      Value="{StaticResource BrushWhite}"/>
    </Style>

    <!-- ═══ ComboBox ═══════════════════════════════════════════════════ -->
    <Style TargetType="ComboBox">
        <Setter Property="FontFamily"  Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="Padding"     Value="8,4"/>
        <Setter Property="Height"      Value="32"/>
        <Setter Property="Background"  Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
    </Style>

    <!-- ═══ CheckBox ═══════════════════════════════════════════════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily"     Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"       Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══ TabControl ═════════════════════════════════════════════════ -->
    <Style TargetType="TabControl">
        <Setter Property="Background"  Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Padding"    Value="16,6"/>
    </Style>

    <!-- ═══ ListBox ════════════════════════════════════════════════════ -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Padding"    Value="6,3"/>
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"   Value="11.5"/>
    </Style>

    <!-- ═══ TreeView ═══════════════════════════════════════════════════ -->
    <Style TargetType="TreeView">
        <Setter Property="Background"  Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"    Value="11.5"/>
    </Style>
    <Style TargetType="TreeViewItem">
        <Setter Property="Padding"  Value="2,2"/>
        <Setter Property="IsExpanded" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <!-- ═══ ProgressBar ════════════════════════════════════════════════ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height"     Value="6"/>
        <Setter Property="Background" Value="{StaticResource BrushCard}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushBlue}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ═══ ScrollBar (schlank) ════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
    </Style>

    <!-- ═══ Separator ══════════════════════════════════════════════════ -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BrushBorder}"/>
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Margin"     Value="0,6"/>
    </Style>

    <!-- ═══ Label ══════════════════════════════════════════════════════ -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Padding"    Value="0"/>
    </Style>

</ResourceDictionary>
